{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm ci --prefix frontend && npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 300,
      "excludeFiles": "{frontend/**,tests/**,docs/**,scripts/**,docker/**,.github/**,models/**,src/social_automation/web/**,src/social_automation/canva/**,**/__pycache__/**,**/*.pyc,**/.pytest_cache/**,**/.ruff_cache/**,**/.venv/**,**/node_modules/**,**/.git/**,**/googleapiclient/discovery_cache/**,Dockerfile,docker-compose.yml,README*.md,*.example}"
    }
  },
  "headers": [
    {
      "source": "/api/v1/batches/(.*)/events",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "X-Accel-Buffering", "value": "no" }
      ]
    }
  ]
}
