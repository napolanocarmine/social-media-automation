# Copia in .env e compila i valori (non committare .env)

# Google Drive (OAuth2 desktop / installed app)
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json
# macOS: apri la pagina di consenso Google in Safari invece del browser predefinito
GOOGLE_OAUTH_BROWSER=safari

# Canva Connect (quando disponibile)
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
CANVA_REDIRECT_URI=http://127.0.0.1:8080/callback
CANVA_OAUTH_SCOPES=asset:read asset:write design:meta:read design:content:read design:content:write profile:read
CANVA_TOKEN_PATH=canva_token.json
CANVA_CONFIG_PATH=config/canva.yaml

# Meta Graph API (IG + FB Page)
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
# Opzionale: user token (Explorer) solo per CLI meta-refresh-page-token — non committare
META_USER_ACCESS_TOKEN=
# Opzionale: id numerico Page se hai più Page e usi meta-refresh-page-token senza --page-id
META_PAGE_ID=
# Opzionale: file (una riga) con solo il Page token; se esiste, ha priorità su META_PAGE_ACCESS_TOKEN
# Opzionale: root assoluta del repo se Streamlit non trova .env/token (deve contenere src/social_automation/)
# SOCIAL_AUTOMATION_ROOT=/percorso/assoluto/social-media-automation
META_PAGE_TOKEN_FILE=output/meta_page_token.txt
# Opzionale: redirect per Facebook Login (meta-oauth-page-token); deve matchare l'app Meta (preferisci https)
META_REDIRECT_URI=http://127.0.0.1:8765/oauth/facebook/callback
# Porta locale del callback (con ngrok: stessa porta di `ngrok http …`)
META_OAUTH_LISTEN_PORT=8765
# Scope OAuth (virgole, no spazi). Per programmare post sulla Page servono permessi abilitati sull'app
# e scope coerenti (es. pages_manage_posts; Meta può richiedere anche pages_read_engagement). Rimuovi
# dalla lista i permessi che il dialog segnala come «Invalid Scopes».
META_OAUTH_SCOPES=pages_show_list,pages_manage_posts,pages_read_engagement
# Opzionale: dialog OAuth con auth_type=rerequest (come flag --oauth-rerequest sulla CLI)
# META_OAUTH_AUTH_TYPE=rerequest
# Opzionale: solo per https://127.0.0.1 nel redirect — certificati PEM (es. mkcert)
META_OAUTH_TLS_CERTFILE=
META_OAUTH_TLS_KEYFILE=
# ID utente Instagram (Graph API), collegato alla Page — richiesto per publish-test instagram
META_IG_USER_ID=
# Pianificazione IG: vedi docs/instagram_graph_api_scheduler_notes.md (DB + dispatch-scheduled; container ~24h)
# Opzionale: versione Graph (default v22.0)
META_GRAPH_VERSION=v22.0
# TLS verso graph.facebook.com. Se CERTIFICATE_VERIFY_FAILED / self-signed in chain: prova false
# (disattiva proxy da HTTPS_PROXY) oppure CLI: meta-oauth-page-token --graph-no-proxy
META_GRAPH_HTTP_TRUST_ENV=true
META_GRAPH_HTTP_CA_BUNDLE=

# Validazione immagine brand (API OpenAI-compatible + vision)
VISION_API_KEY=
VISION_MODEL=gpt-4o-mini
# Opzionale: base URL per provider compatibili OpenAI (default api.openai.com)
VISION_API_BASE_URL=
# TLS verso OpenAI/Vision (Story AI, image edit). Se omessi, eredita META_GRAPH_HTTP_*.
# Con proxy aziendale MITM: false evita HTTPS_PROXY; oppure PEM CA aziendale.
# VISION_HTTP_TRUST_ENV=false
# VISION_HTTP_CA_BUNDLE=
# Prompt brand per categoria: config/vision_brand.yaml (copia da vision_brand.example.yaml)

# Gate dispatch automatico (launchd / dispatch-scheduled)
DISPATCH_REQUIRE_APPROVAL=true
DISPATCH_REQUIRE_QUALITY_PASS=false
DISPATCH_REQUIRE_VISION_PASS=true

# Story AI Assistant (ritocco fotografico + copy)
# Usa le stesse variabili vision OpenAI-compatible
# Story AI Assistant — 3 layer (vedi docs/story-ai-assistant-gpt.md)
# STORY_SYSTEM_PATH=config/brand/story_system.md
# STORY_BUSINESS_RULES_PATH=config/brand/story_business_rules.md
# STORY_AGENT_CONFIG_PATH=config/brand/story_agent.md
# BRAND_KNOWLEDGE_PATH=config/brand/story_business_rules.md  # legacy alias layer 2
# VISUAL_USE_AI_IMAGE_EDIT=false
# VISUAL_DISABLE_PILLOW_RETOUCH=false
# VISUAL_REVIEW_ENABLED=false
# VISUAL_PRODUCE_MODE=generative
# VISUAL_EDIT_INCLUDE_KB=true
# VISUAL_SKIP_POST_CROP=false
# VISUAL_IMAGE_BACKEND=responses
# VISUAL_RESPONSES_MODEL=gpt-5.5
# VISUAL_RESPONSES_IMAGE_MODEL=gpt-image-1.5
# VISUAL_IMAGE_MODEL=gpt-image-1
# Lasciare vuoto per size dinamica per crop_mode (consigliato). Forzare solo se serve.
# VISUAL_IMAGE_SIZE=
# VISUAL_IMAGE_INPUT_FIDELITY=high
# VISUAL_IMAGE_QUALITY=high
# VISUAL_EDIT_PLAN_ENABLED=true
# VISUAL_EDIT_PLAN_MODEL=gpt-4o
# VISUAL_GPT_PURE_MODE=false
# VISUAL_HYBRID_TONE_PIPELINE=false
# VISUAL_EDIT_PROMPT_COMPILER=false
# VISUAL_PRECROP_BEFORE_API=false
# VISUAL_EDIT_PROMPT_COMPILER=true
# VISUAL_PRECROP_BEFORE_API=true
# VISUAL_JPEG_EXPORT_QUALITY=95
# VISUAL_EDIT_DEBUG_LOG=false
# VISUAL_REVIEW_SCORE_USE_ORIGINAL=8.0
# VISUAL_REVIEW_SCORE_MANUAL=5.0
# VISUAL_PRODUCER_PROMPT_PATH=config/brand/image_edit_task_prompt.md

# Calendario editoriale (slot fissi); copia schedule.example.yaml → schedule.yaml
SCHEDULE_CONFIG_PATH=config/schedule.yaml
# Margine sotto soglia ONNX per immagini «borderline» in prepare-week
IMAGE_QUALITY_BORDERLINE_MARGIN=0.15

# Database locale SQLite
DB_PATH=output/social_automation.db

# Fuso orario applicativo (UI, pianificazione, dispatch)
APP_TIMEZONE=Europe/Rome

# Dispatcher schedulazione (opzionale: launchd su macOS o servizio scheduler in Docker)
# Intervallo dispatch automatico: default 10 minuti (600s). Il dispatch manuale resta sempre
# disponibile da UI (⑤ Pubblica), API POST /api/v1/dispatch/run e CLI dispatch-scheduled.
# DISPATCH_INTERVAL_SECONDS=600
# DISPATCH_LIMIT=100
# DISPATCH_PLATFORM=instagram
# STREAMLIT_PORT=8501
