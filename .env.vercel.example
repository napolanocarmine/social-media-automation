# === Database (auto da Neon integration) ===
# DATABASE_URL=                    # oppure NEON_DB_DATABASE_URL se risorsa con prefisso
# DATABASE_URL_UNPOOLED=             # oppure NEON_DB_DATABASE_URL_UNPOOLED
DB_BACKEND=postgres

# === Storage (auto da Blob integration) ===
# BLOB_READ_WRITE_TOKEN=
STORAGE_BACKEND=vercel_blob

# === Meta ===
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
META_IG_USER_ID=
META_GRAPH_VERSION=v22.0

# === Google Drive ===
GOOGLE_CREDENTIALS_JSON=
GOOGLE_REFRESH_TOKEN=
# GOOGLE_REDIRECT_URI=https://your-app.vercel.app/api/v1/oauth/google/callback

# === Story AI ===
VISION_API_KEY=
VISION_MODEL=gpt-4o-mini

# === Dispatch / Cron ===
CRON_SECRET=
DISPATCH_REQUIRE_APPROVAL=true
DISPATCH_REQUIRE_QUALITY_PASS=false
DISPATCH_LIMIT=100
DISPATCH_CRON_HOUR_START=11
DISPATCH_CRON_HOUR_END=22

# === App ===
APP_TIMEZONE=Europe/Rome
API_CORS_ORIGINS=https://your-app.vercel.app

# === Dev locale (override) ===
# DB_BACKEND=sqlite
# STORAGE_BACKEND=local
# DB_PATH=output/social_automation.db
